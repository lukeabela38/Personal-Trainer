# ── Personal Trainer ──────────────────────────────────────────────────
# Environment configuration for the live data pipeline.
# Copy this file to .env and fill in your values.
# .env is gitignored — secrets stay local.

# ── Source Commands ───────────────────────────────────────────────────
# These tell the pipeline which commands to run for each data source.
# Default points to the MCP wrapper scripts in scripts/wrappers/.
# Use relative paths so the same file works both inside Docker (WORKDIR /app)
# and when running from the repo root on the host.

PERSONAL_TRAINER_GARMIN_COMMAND=python3 scripts/wrappers/fetch_garmin.py
PERSONAL_TRAINER_HEVY_COMMAND=python3 scripts/wrappers/fetch_hevy.py
PERSONAL_TRAINER_CRONOMETER_COMMAND=python3 scripts/wrappers/fetch_cronometer.py
PERSONAL_TRAINER_HEVY_STRENGTH_COMMAND=python3 scripts/wrappers/fetch_hevy_strength.py
PERSONAL_TRAINER_HEVY_STRENGTH_RECENT_DAYS=30
PERSONAL_TRAINER_GARMIN_SPEED_COMMAND=python3 scripts/wrappers/fetch_garmin_speed.py

# ── Combined Source Loading (alternative to per-source commands) ──────
# Set either to load all sources from one JSON payload instead.
# PERSONAL_TRAINER_SOURCES_FILE=/path/to/sources.json
# PERSONAL_TRAINER_SOURCES_COMMAND=python3 /path/to/emitter-script.py

# ── Credentials (set these to bypass MCP servers) ────────────────────
# Garmin Connect credentials — used by the wrapper scripts directly
# (via garminconnect library). The wrapper caches reusable session tokens.
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Garmin tokenstore directory used to cache reusable session tokens.
# Defaults to ~/.garminconnect when unset.
GARMINTOKENS=

# Hevy API key — required (stored in macOS Keychain by default).
# HEVY_API_KEY=your_key_here

# Cronometer credentials — required if not using the keychain wrapper.
# CRONOMETER_USERNAME=your_email
# CRONOMETER_PASSWORD=your_password
# CRONOMETER_SESSION_FILE=/path/to/.cronometer_session.json

# ── MCP Server Commands (optional overrides) ────────────────────────
# Only needed if you're using MCP mode (no GARMIN_EMAIL set above)
# or if the default uvx/npx commands don't work for you.
# PERSONAL_TRAINER_GARMIN_MCP_COMMAND=uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp
# PERSONAL_TRAINER_HEVY_MCP_COMMAND=npx -y -p node@26 -p hevy-mcp hevy-mcp
# PERSONAL_TRAINER_CRONOMETER_MCP_COMMAND=uvx cronometer-api-mcp

# ── Manual Check-In (alternative) ─────────────────────────────────────
# PERSONAL_TRAINER_MANUAL_FILE=/path/to/checkin.json
