# ── Personal Trainer ──────────────────────────────────────────────────
# Environment configuration for the live data pipeline.
# Copy this file to .env and fill in your values.
# .env is gitignored — secrets stay local.

# ── Source Commands ───────────────────────────────────────────────────
# These tell the pipeline which commands to run for each data source.
# Default points to the MCP wrapper scripts in scripts/wrappers/.
REPO_ROOT=/Users/labela/Documents/luke/Personal-Trainer

PERSONAL_TRAINER_GARMIN_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_garmin.py
PERSONAL_TRAINER_HEVY_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_hevy.py
PERSONAL_TRAINER_CRONOMETER_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_cronometer.py
PERSONAL_TRAINER_MANUAL_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_manual.py
PERSONAL_TRAINER_GARMIN_SPEED_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_garmin_speed.py
PERSONAL_TRAINER_HEVY_STRENGTH_COMMAND=python3 $REPO_ROOT/scripts/wrappers/fetch_hevy_strength.py

# ── Combined Source Loading (alternative to per-source commands) ──────
# Set either to load all sources from one JSON payload instead.
# PERSONAL_TRAINER_SOURCES_FILE=/path/to/sources.json
# PERSONAL_TRAINER_SOURCES_COMMAND=python3 /path/to/emitter-script.py

# ── MCP Server Commands (optional) ────────────────────────────────────
# These control how the MCP server itself is launched.
# The defaults use uvx/npx and work on this machine.
# PERSONAL_TRAINER_GARMIN_MCP_COMMAND=/opt/homebrew/bin/uvx --python 3.12 --from git+https://github.com/Taxuspt/garmin_mcp garmin-mcp
# PERSONAL_TRAINER_HEVY_MCP_COMMAND=/opt/homebrew/bin/npx -y -p node@26 -p hevy-mcp hevy-mcp
# PERSONAL_TRAINER_CRONOMETER_MCP_COMMAND=/opt/homebrew/bin/uvx cronometer-api-mcp

# ── Manual Check-In (alternative) ─────────────────────────────────────
# PERSONAL_TRAINER_MANUAL_FILE=/path/to/checkin.json
